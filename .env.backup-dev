# ── Graph Provider ──────────────────────────────────────────────────
GRAPH_PROVIDER=falkordb

# ── Management Database ────────────────────────────────────────────
# MANAGEMENT_DB_URL=postgresql+asyncpg://user:pass@host:5432/dbname
# DB_ECHO=false

# ── Credential Encryption ─────────────────────────────────────────
# CREDENTIAL_ENCRYPTION_KEY=   # Fernet key; omit for plaintext in dev

# ── Authentication (JWT) ──────────────────────────────────────────
# JWT_SECRET_KEY=              # REQUIRED in production; auto-generated in dev
# JWT_ALGORITHM=HS256          # Default
# JWT_EXPIRY_MINUTES=15        # Access-cookie lifetime (default 15)
# JWT_REFRESH_EXPIRY_DAYS=7    # Refresh-cookie lifetime (default 7)

# ── Session cookies ───────────────────────────────────────────────
# Cookies default to Secure=true (HTTPS-only) for production safety.
# Dev runs over HTTP, so browsers silently drop Secure cookies — set
# this to false locally or you'll get "CSRF token missing or invalid"
# 403s on every POST/PUT/PATCH/DELETE because the cookie never sticks.
AUTH_COOKIE_SECURE=false
# AUTH_COOKIE_SAMESITE=lax     # Default; use 'strict' for tighter top-nav
# AUTH_COOKIE_DOMAIN=          # Set when sharing a session across subdomains

# ── Bootstrap Admin ───────────────────────────────────────────────
# Created automatically on first run if no users exist.
ADMIN_EMAIL=admin@nexuslineage.local     # Default
ADMIN_PASSWORD=changeme                   # Default — change after first login!
