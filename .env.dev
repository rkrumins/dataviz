# ══════════════════════════════════════════════════════════════════════
# Synodic — Local Development Environment
# ══════════════════════════════════════════════════════════════════════
# Format: KEY=VALUE (no `export` keyword).
#
# ./dev.sh reads this via `set -a; source .env.dev; set +a` so every
# value is exported into child processes. It is also passed to
# docker compose via `--env-file .env.dev` — the same file feeds both.
#
# This file is gitignored. Copy .env.example to start over.
# ══════════════════════════════════════════════════════════════════════

# ── Postgres ────────────────────────────────────────────────────────
POSTGRES_USER=synodic
POSTGRES_PASSWORD=synodic
POSTGRES_DB=synodic
POSTGRES_PORT=5432

# ── Redis ───────────────────────────────────────────────────────────
REDIS_PORT=6380
REDIS_URL=redis://localhost:6380/0

# ── FalkorDB ────────────────────────────────────────────────────────
FALKORDB_PORT=6379
FALKORDB_UI_PORT=3000
FALKORDB_HOST=localhost
FALKORDB_GRAPH_NAME=nexus_lineage

# ── Backend connection strings ──────────────────────────────────────
MANAGEMENT_DB_URL=postgresql+asyncpg://synodic:synodic@localhost:5432/synodic

# ── Auth ────────────────────────────────────────────────────────────
JWT_SECRET_KEY=dev-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRY_MINUTES=60
ADMIN_EMAIL=admin@nexuslineage.local
ADMIN_PASSWORD=admin123

# ── Graph Provider Bootstrap ────────────────────────────────────────
GRAPH_PROVIDER=falkordb

# ── CORS ────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:3080,http://localhost:5173,http://localhost:3000

# ── Logging ─────────────────────────────────────────────────────────
LOG_LEVEL=INFO
