# ══════════════════════════════════════════════════════════════════════
# Synodic — Self-Host / Production Env Template
# ══════════════════════════════════════════════════════════════════════
# Copy to .env and edit before `./deploy.sh up`:
#   cp .env.prod.example .env
#   $EDITOR .env                     # set REPLACE_ME values
#   ./deploy.sh up
#
# The deploy preflight refuses to start if any REPLACE_ME value remains.
# ══════════════════════════════════════════════════════════════════════

# ── Postgres (management database) ──────────────────────────────────
# Change POSTGRES_PASSWORD. POSTGRES_USER / POSTGRES_DB can stay.
POSTGRES_USER=synodic
POSTGRES_PASSWORD=REPLACE_ME
POSTGRES_DB=synodic
POSTGRES_PORT=5432

# ── Redis / FalkorDB (usually don't change) ─────────────────────────
REDIS_PORT=6380
FALKORDB_PORT=6379
FALKORDB_UI_PORT=3000
FALKORDB_GRAPH_NAME=nexus_lineage

# ── App ports (host-side) ───────────────────────────────────────────
VIZ_PORT=8000
GRAPH_PORT=8001
CONTROLPLANE_PORT=8091
FRONTEND_PORT=3080

# ── Auth — MUST CHANGE ──────────────────────────────────────────────
# Generate a strong JWT secret:
#   openssl rand -hex 48
JWT_SECRET_KEY=REPLACE_ME
JWT_ALGORITHM=HS256
JWT_EXPIRY_MINUTES=60

# Admin account created on first boot (if no users exist). Change after
# first login via the UI.
ADMIN_EMAIL=admin@synodic.local
ADMIN_PASSWORD=REPLACE_ME

# ── Credential Encryption ───────────────────────────────────────────
# Fernet key for encrypting stored provider credentials. Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Leave blank for plaintext storage (not recommended for production).
CREDENTIAL_ENCRYPTION_KEY=

# ── Graph Provider Bootstrap ────────────────────────────────────────
GRAPH_PROVIDER=falkordb

# ── Worker tuning ───────────────────────────────────────────────────
WORKER_CONCURRENCY=4
MAX_CONCURRENT_PER_GRAPH=2
AGGREGATION_JOB_TIMEOUT_SECS=7200

# ── CORS (change to your actual domain) ─────────────────────────────
# Example for public hostname:
#   CORS_ALLOWED_ORIGINS=https://synodic.example.com
CORS_ALLOWED_ORIGINS=http://localhost:3080

# ── Logging ─────────────────────────────────────────────────────────
LOG_LEVEL=INFO
